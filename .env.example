# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-app.up.railway.app/telegram-webhook

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Sheets (service account JSON as a single-line string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# SQLite (Railway persistent volume mounts at /data)
DATABASE_PATH=/data/kitchen.db

# Admin (comma-separated Telegram chat IDs)
ADMIN_CHAT_IDS=123456789
